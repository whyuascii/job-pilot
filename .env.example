# Database (Supabase PostgreSQL in production, local Postgres in dev)
DATABASE_URL=postgresql://jobpilot:jobpilot@localhost:5432/jobpilot

# Redis
REDIS_URL=redis://:jobpilot@localhost:6379

# Anthropic / Claude API
ANTHROPIC_API_KEY=

# AWS Bedrock (alternative to direct Anthropic)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Firecrawl
FIRECRAWL_API_KEY=

# S3-compatible storage (MinIO for local dev, Supabase Storage in production)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=job-pilot
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# App
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
NODE_ENV=development

# Auth (better-auth)
BETTER_AUTH_SECRET=local-dev-secret-must-be-at-least-32-characters-long
SESSION_SECRET=change-me-in-production-at-least-32-chars!!

# Encryption key for API key storage (optional, falls back to BETTER_AUTH_SECRET)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# RxResume (PDF generation)
RXRESUME_URL=http://localhost:3100

# Google OAuth (Gmail integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/settings/gmail/callback

# PostHog Analytics
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
